<h1>Analytics</h1>

<form action="/charts" method="get" class="filter-form" id="chartFilters">
  <label for="programme">Programme</label>
  <input
    type="text"
    id="programme"
    name="programme"
    value="{{filters.programme}}"
    placeholder="e.g. BSc (Hons) Computer Science"
  />

  <label for="graduationYear">Graduation year</label>
  <input
    type="number"
    id="graduationYear"
    name="graduationYear"
    value="{{filters.graduationYear}}"
    placeholder="e.g. 2021"
  />

  <button type="submit">Apply filters</button>
  <a href="/charts" class="filter-clear">Clear</a>
</form>

<div class="charts-grid">
  <div class="chart-card">
    <h2>Curriculum skills gap</h2>
    <p class="chart-subtitle">Post-graduation certifications and courses, ranked
      by completion frequency</p>
    {{#if chartData.skillsGap.length}}
      <div class="chart-canvas-wrap"><canvas id="skillsGapChart"></canvas></div>
      <ul class="chart-legend-key">
        <li><span class="legend-dot legend-critical"></span> Critical</li>
        <li><span class="legend-dot legend-significant"></span> Significant</li>
        <li><span class="legend-dot legend-emerging"></span> Emerging</li>
      </ul>
    {{else}}
      <p class="chart-empty">No data for these filters.</p>
    {{/if}}
  </div>

  <div class="chart-card">
    <h2>Employment by industry sector</h2>
    {{#if chartData.employmentSectors.length}}
      <div class="chart-canvas-wrap"><canvas
          id="employmentSectorsChart"
        ></canvas></div>
    {{else}}
      <p class="chart-empty">No data for these filters.</p>
    {{/if}}
  </div>

  <div class="chart-card">
    <div class="chart-card-header">
      <h2>Most common job titles</h2>
      <label for="jobTitlesLimit">Top
        <input
          type="number"
          id="jobTitlesLimit"
          name="jobTitlesLimit"
          value="{{filters.jobTitlesLimit}}"
          min="1"
          max="50"
          form="chartFilters"
          class="n-input"
        />
      </label>
    </div>
    {{#if chartData.jobTitles.length}}
      <div class="chart-canvas-wrap"><canvas id="jobTitlesChart"></canvas></div>
    {{else}}
      <p class="chart-empty">No data for these filters.</p>
    {{/if}}
  </div>

  <div class="chart-card">
    <div class="chart-card-header">
      <h2>Top employers</h2>
      <label for="employersLimit">Top
        <input
          type="number"
          id="employersLimit"
          name="employersLimit"
          value="{{filters.employersLimit}}"
          min="1"
          max="50"
          form="chartFilters"
          class="n-input"
        />
      </label>
    </div>
    {{#if chartData.employers.length}}
      <div class="chart-canvas-wrap"><canvas id="employersChart"></canvas></div>
    {{else}}
      <p class="chart-empty">No data for these filters.</p>
    {{/if}}
  </div>

  <div class="chart-card">
    <h2>Geographic distribution</h2>
    {{#if chartData.locations.length}}
      <div class="chart-canvas-wrap"><canvas id="locationsChart"></canvas></div>
    {{else}}
      <p class="chart-empty">No data for these filters.</p>
    {{/if}}
  </div>

  <div class="chart-card">
    <div class="chart-card-header">
      <h2>Certification growth over time</h2>
      <label for="certGrowthPeriod">
        <select id="certGrowthPeriod" name="certGrowthPeriod" form="chartFilters">
          <option value="6" {{#if (eq filters.certGrowthPeriod "6")}}selected{{/if}}>Last 6 months</option>
          <option value="12" {{#if (eq filters.certGrowthPeriod "12")}}selected{{/if}}>Last 12 months</option>
          <option value="all" {{#if (eq filters.certGrowthPeriod "all")}}selected{{/if}}>All time</option>
        </select>
      </label>
    </div>
    {{#if chartData.certGrowth.length}}
      <div class="chart-canvas-wrap"><canvas id="certGrowthChart"></canvas></div>
    {{else}}
      <p class="chart-empty">No data for these filters.</p>
    {{/if}}
  </div>

  <div class="chart-card">
    <h2>Post-graduation course completions</h2>
    {{#if chartData.courses.length}}
      <div class="chart-canvas-wrap"><canvas id="coursesChart"></canvas></div>
    {{else}}
      <p class="chart-empty">No data for these filters.</p>
    {{/if}}
  </div>

  <div class="chart-card">
    <h2>Profile completion by cohort</h2>
    <p class="chart-subtitle">Average profile completion percentage, grouped by graduation year</p>
    {{#if chartData.completion.length}}
      <div class="chart-canvas-wrap"><canvas id="completionChart"></canvas></div>
    {{else}}
      <p class="chart-empty">No data for these filters.</p>
    {{/if}}
  </div>
</div>

<script>const chartData = {{{json chartData}}};</script>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4"></script>
<script src="/charts.js"></script>