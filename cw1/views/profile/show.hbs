<h1>My profile</h1>

<p>Profile completion: {{completionPercent}}%</p>

{{#if profile.profileImage}}
  <img src="{{profile.profileImage}}" alt="Profile image" class="profile-image">
{{/if}}

<h2>{{profile.fullName}}</h2>
{{#if profile.bio}}<p>{{profile.bio}}</p>{{/if}}
{{#if profile.linkedinUrl}}<p><a href="{{profile.linkedinUrl}}" target="_blank" rel="noopener">LinkedIn</a></p>{{/if}}

<p><a href="/profile/edit">Edit profile</a></p>

{{!-- Credential sections --}}
{{> credential_section items=degrees resourcePath="degrees" sectionTitle="Degrees" sectionTitleSingular="degree" csrfToken=csrfToken}}

{{> credential_section items=certifications resourcePath="certifications" sectionTitle="Certifications" sectionTitleSingular="certification" csrfToken=csrfToken}}

{{> credential_section items=licences resourcePath="licences" sectionTitle="Licences" sectionTitleSingular="licence" csrfToken=csrfToken}}

{{> credential_section items=courses resourcePath="courses" sectionTitle="Professional courses" sectionTitleSingular="course" csrfToken=csrfToken}}

{{> employment_section items=employment csrfToken=csrfToken}}

{{> event_attendance_section eventAttendances=eventAttendances profile=profile csrfToken=csrfToken}}
