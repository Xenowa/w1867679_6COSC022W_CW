<section class="profile-section">
  <h3>{{sectionTitle}}</h3>

  <div class="credential-list">
    {{#each items}}
      <details class="credential-item">
        <summary>{{this.title}} - {{this.institution}}</summary>

        <form action="/profile/{{../resourcePath}}/{{this.id}}?_method=PUT" method="post" class="auth-form">
          <input type="hidden" name="_csrf" value="{{../csrfToken}}">

          <label>Title</label>
          <input type="text" name="title" value="{{this.title}}" required>

          <label>Institution</label>
          <input type="text" name="institution" value="{{this.institution}}" required>

          <label>URL (optional)</label>
          <input type="url" name="url" value="{{this.url}}" placeholder="https://...">

          <label>Completed on</label>
          <input type="date" name="completedAt" value="{{formatDateInput this.completedAt}}" required>

          <button type="submit">Save changes</button>
        </form>

        <form action="/profile/{{../resourcePath}}/{{this.id}}?_method=DELETE" method="post">
          <input type="hidden" name="_csrf" value="{{../csrfToken}}">
          <button type="submit" class="delete-button">Delete</button>
        </form>
      </details>
    {{else}}
      <p class="credential-empty">None added yet.</p>
    {{/each}}
  </div>

  <details class="credential-add">
    <summary>Add {{sectionTitleSingular}}</summary>
    <form action="/profile/{{resourcePath}}" method="post" class="auth-form">
      <input type="hidden" name="_csrf" value="{{csrfToken}}">

      <label>Title</label>
      <input type="text" name="title" placeholder="e.g. BSc (Hons) Computer Science" required>

      <label>Institution</label>
      <input type="text" name="institution" placeholder="e.g. University of Westminster" required>

      <label>URL (optional)</label>
      <input type="url" name="url" placeholder="https://...">

      <label>Completed on</label>
      <input type="date" name="completedAt" required>

      <button type="submit">Add</button>
    </form>
  </details>
</section>
